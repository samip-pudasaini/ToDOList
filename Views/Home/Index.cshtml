@{
    ViewData["Title"] = "Home Page";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@@0,9..144,300;0,9..144,400;1,9..144,300&family=DM+Sans:wght@@300;400;500&display=swap');

    body {
        font-family: 'DM Sans', sans-serif;
    }

    .hero-section {
        min-height: 88vh;
        display: flex;
        align-items: center;
        background: #ffffff;
        border-bottom: 1px solid #e9ecef;
    }

    .hero-headline {
        font-family: 'Fraunces', serif;
        font-size: clamp(40px, 5.5vw, 72px);
        font-weight: 300;
        letter-spacing: -2px;
        line-height: 1.08;
        color: #212529;
    }

        .hero-headline em {
            font-style: italic;
            color: #0d6efd;
        }

    .hero-sub {
        font-size: 17px;
        color: #6c757d;
        font-weight: 300;
        line-height: 1.7;
        max-width: 430px;
    }

    /* Browser mock frame */
    .browser-frame {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 12px;
        box-shadow: 0 8px 48px rgba(0,0,0,0.10);
        overflow: hidden;
    }

    .browser-bar {
        background: #f3f4f6;
        border-bottom: 1px solid #dee2e6;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .browser-dots {
        display: flex;
        gap: 5px;
    }

        .browser-dots span {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: block;
        }

    .dot-red {
        background: #ff5f57;
    }

    .dot-yellow {
        background: #febc2e;
    }

    .dot-green {
        background: #28c840;
    }

    .browser-url {
        flex: 1;
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 5px;
        padding: 4px 12px;
        font-size: 11px;
        color: #adb5bd;
    }

    /* App UI mock */
    .app-mock {
        display: flex;
        height: 360px;
        font-size: 13px;
    }

    .mock-sidebar {
        width: 190px;
        flex-shrink: 0;
        background: #f8f9fa;
        border-right: 1px solid #dee2e6;
        padding: 16px 10px;
    }

    .mock-sidebar-title {
        font-size: 14px;
        color: #6c757d;
        text-align: center;
        padding-bottom: 10px;
        border-bottom: 1px solid #dee2e6;
        margin-bottom: 8px;
    }

    .mock-list-item {
        padding: 8px 12px;
        border-radius: 8px;
        font-weight: 500;
        color: #212529;
        margin-bottom: 2px;
    }

        .mock-list-item.active {
            background: #212529;
            color: #fff;
        }

    .mock-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .mock-main-header {
        padding: 14px 18px 12px;
        border-bottom: 1px solid #dee2e6;
        font-size: 14px;
        color: #6c757d;
        text-align: center;
    }

    .mock-tasks {
        flex: 1;
        padding: 8px 12px;
        overflow: hidden;
    }

    .mock-task {
        padding: 9px 10px;
        border-bottom: 1px solid #f1f3f5;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .mock-task-name {
        font-weight: 600;
        color: #212529;
    }

        .mock-task-name.done {
            text-decoration: line-through;
            color: #adb5bd;
        }

    .mock-task-meta {
        font-size: 11px;
        color: #adb5bd;
    }

    .mock-badge {
        font-size: 10px;
        font-weight: 600;
        padding: 2px 7px;
        border-radius: 20px;
        text-transform: uppercase;
    }

    .badge-high {
        background: #fff0f0;
        color: #dc2626;
    }

    .badge-med {
        background: #fffbeb;
        color: #d97706;
    }

    .badge-low {
        background: #f0fdf4;
        color: #16a34a;
    }

    .mock-footer {
        padding: 10px 12px;
        border-top: 1px solid #dee2e6;
    }

        .mock-footer input {
            width: 100%;
            padding: 7px 12px;
            border: 1px solid #dee2e6;
            border-radius: 6px;
            font-size: 12px;
            color: #adb5bd;
            background: #f8f9fa;
            outline: none;
        }

    /* Features section */
    .features-section {
        padding: 90px 0;
        background: #fff;
        border-top: 1px solid #e9ecef;
    }

    .section-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #0d6efd;
        margin-bottom: 12px;
    }

    .section-title {
        font-family: 'Fraunces', serif;
        font-size: clamp(28px, 3.5vw, 42px);
        font-weight: 300;
        letter-spacing: -1px;
        color: #212529;
        margin-bottom: 48px;
    }

    .feature-card {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        padding: 28px;
        height: 100%;
        transition: box-shadow 0.2s, transform 0.2s;
    }

        .feature-card:hover {
            box-shadow: 0 8px 32px rgba(0,0,0,0.08);
            transform: translateY(-3px);
        }

    .feature-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-bottom: 16px;
    }

    .feature-title {
        font-size: 15px;
        font-weight: 600;
        color: #212529;
        margin-bottom: 6px;
    }

    .feature-desc {
        font-size: 14px;
        color: #6c757d;
        line-height: 1.6;
    }

    /* Calendar dark section */
    .calendar-section {
        background: #212529;
        padding: 90px 0;
        color: #fff;
    }

        .calendar-section .section-label {
            color: rgba(255,255,255,0.4);
        }

        .calendar-section .section-title {
            color: #fff;
        }

    .cal-desc {
        font-size: 15px;
        color: rgba(255,255,255,0.55);
        line-height: 1.7;
    }

    .cal-preview {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 14px;
        overflow: hidden;
    }

    .cal-header {
        padding: 14px 18px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .cal-month {
        font-family: 'Fraunces', serif;
        font-size: 18px;
        font-weight: 300;
    }

    .cal-nav-btn {
        width: 28px;
        height: 28px;
        background: rgba(255,255,255,0.1);
        border-radius: 5px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: rgba(255,255,255,0.6);
    }

    .cal-grid {
        padding: 10px 14px 14px;
    }

    .cal-days-row {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        margin-bottom: 4px;
    }

    .cal-day-name {
        text-align: center;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        color: rgba(255,255,255,0.3);
        padding: 4px 0;
    }

    .cal-cells {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
    }

    .cal-cell {
        border-radius: 5px;
        padding: 4px 5px;
        font-size: 11px;
        color: rgba(255,255,255,0.35);
        min-height: 48px;
        position: relative;
    }

        .cal-cell.today {
            background: rgba(13,110,253,0.35);
            color: #fff;
        }

        .cal-cell.has-event {
            background: rgba(255,255,255,0.04);
        }

    .cal-event {
        position: absolute;
        bottom: 4px;
        left: 4px;
        display: flex;
        align-items: center;
        gap: 3px;
        font-size: 9px;
        color: rgba(255,255,255,0.55);
        white-space: nowrap;
        overflow: hidden;
        max-width: calc(100% - 8px);
    }

    .cal-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* Edit panel mock */
    .panel-mock {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 14px;
        padding: 22px;
    }

    .panel-label-small {
        font-size: 10px;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 5px;
    }

    .panel-value {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 6px;
        padding: 8px 11px;
        font-size: 13px;
        color: rgba(255,255,255,0.65);
        margin-bottom: 14px;
    }

    /* CTA */
    .cta-section {
        padding: 100px 0;
        background: #f8f9fa;
        text-align: center;
        border-top: 1px solid #e9ecef;
    }

    .cta-title {
        font-family: 'Fraunces', serif;
        font-size: clamp(32px, 4vw, 56px);
        font-weight: 300;
        letter-spacing: -1.5px;
        color: #212529;
        margin-bottom: 14px;
    }

    .cta-sub {
        font-size: 16px;
        color: #6c757d;
        margin-bottom: 36px;
    }
</style>


<!-- ── HERO ── -->
<section class="hero-section">
    <div class="container py-5">
        <div class="row align-items-center g-5">

            <div class="col-lg-5">
                <p class="section-label">Your personal task manager</p>
                <h1 class="hero-headline mb-4">
                    Stay on top of <em>everything</em> that matters.
                </h1>
                <p class="hero-sub mb-5">
                    Organise tasks into lists, set priorities, track due dates, and visualise your workload on a calendar — all in one clean, focused app.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-area="" asp-controller="List" asp-action="Index" class="btn btn-dark btn-lg px-4">
                        Open App →
                    </a>
                    <a href="#features" class="btn btn-outline-secondary btn-lg px-4">
                        See Features
                    </a>
                </div>
            </div>

            <div class="col-lg-7">
                <img src="~/images/List-tasks.png" alt="Task list view" style="width:100%; display:block;" />
            </div>

        </div>
    </div>
</section>


<!-- ── FEATURES ── -->
<section class="features-section" id="features">
    <div class="container">
        <p class="section-label">What's inside</p>
        <h2 class="section-title">Everything you need,<br>nothing you don't.</h2>

        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#eff4ff;">📋</div>
                    <div class="feature-title">Multiple Lists</div>
                    <div class="feature-desc">Create separate lists for projects, personal tasks, or any category you need to stay organised.</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fff0f0;">🔴</div>
                    <div class="feature-title">Priority Levels</div>
                    <div class="feature-desc">Tag tasks as High, Medium, or Low priority so you always know what needs your attention first.</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#f0fdf4;">✅</div>
                    <div class="feature-title">Track Completion</div>
                    <div class="feature-desc">Mark tasks as done and watch them strike through. Keep a clear picture of your progress.</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fffbeb;">📅</div>
                    <div class="feature-title">Due Dates</div>
                    <div class="feature-desc">Assign due dates to every task and never let a deadline slip through the cracks again.</div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- ── CALENDAR SECTION ── -->
<section class="calendar-section">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-lg-4">
                <p class="section-label">Calendar View</p>
                <h2 class="section-title">See your whole month at a glance.</h2>
                <p class="cal-desc mb-4">
                    Switch to the calendar to get a bird's-eye view of every upcoming deadline. Tasks are colour-coded by priority — click any one to edit it right there.
                </p>
                <a asp-area="" asp-controller="Calendar" asp-action="Index" class="btn btn-light px-4">
                    Open Calendar →
                </a>
            </div>

            <div class="col-lg-8">
                <img src="~/images/Calendar.png" alt="Calendar view"
                     style="width:100%; border-radius:14px; border:1px solid rgba(255,255,255,0.12);" />
            </div>
        </div>
    </div>
</section>


<!-- ── FINAL CTA ── -->
<section class="cta-section">
    <div class="container">
        <h2 class="cta-title">Ready to get organised?</h2>
        <p class="cta-sub">Start adding your tasks and never miss a deadline again.</p>
        <a asp-area="" asp-controller="List" asp-action="Index" class="btn btn-dark btn-lg px-5">
            Get Started →
        </a>
    </div>
</section>
